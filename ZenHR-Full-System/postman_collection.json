            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveTypeId\": 1,\n  \"startDate\": \"2026-04-20\",\n  \"endDate\": \"2026-04-21\",\n  \"reason\": \"Personal reason\"\n}"
            },
            "url": "{{baseUrl}}/api/leave/requests"
          }
