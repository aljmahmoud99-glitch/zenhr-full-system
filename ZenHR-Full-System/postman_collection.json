          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeCode\": \"EMP-NEW\",\n  \"firstNameAr\": \"موظف\",\n  \"lastNameAr\": \"جديد\",\n  \"firstNameEn\": \"New\",\n  \"lastNameEn\": \"Employee\",\n  \"gender\": \"male\",\n  \"employmentType\": \"full_time\",\n  \"employmentStatus\": \"active\",\n  \"basicSalary\": 600,\n  \"housingAllowance\": 0,\n  \"transportAllowance\": 0,\n  \"mobileAllowance\": 0,\n  \"mealAllowance\": 0,\n  \"otherAllowances\": 0,\n  \"grossSalary\": 600\n}"
            },
            "url": "{{baseUrl}}/api/employees"
          }
        }
      ]
    },
