        {
          "name": "Create Overtime Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-04-17\",\n  \"hours\": 2,\n  \"reason\": \"Support work\",\n  \"overtimeType\": \"normal\",\n  \"compensationType\": \"payment\"\n}"
            },
            "url": "{{baseUrl}}/api/overtime/requests"
          }
        }
      ]
