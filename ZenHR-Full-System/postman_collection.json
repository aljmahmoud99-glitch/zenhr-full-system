    {
      "name": "Salary Advances",
      "item": [
        { "name": "List Advances", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }], "url": "{{baseUrl}}/api/salary-advances" } },
        {
          "name": "Create Advance Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": {{employeeId}},\n  \"amount\": 150,\n  \"reason\": \"Advance request from Postman\",\n  \"repaymentMethod\": \"monthly\",\n  \"notes\": \"Test request\"\n}"
            },
            "url": "{{baseUrl}}/api/salary-advances"
          }
        },
        {
          "name": "Approve Advance",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approvedAmount\": 150,\n  \"repaymentMethod\": \"monthly\",\n  \"repaymentPlan\": \"3 monthly deductions\",\n  \"notes\": \"Approved by HR\"\n}"
            },
            "url": "{{baseUrl}}/api/salary-advances/{{advanceId}}/approve"
          }
        },
        {
          "name": "Reject Advance",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Rejected by HR\",\n  \"notes\": \"Insufficient justification\"\n}"
            },
            "url": "{{baseUrl}}/api/salary-advances/{{advanceId}}/reject"
          }
        }
      ]
