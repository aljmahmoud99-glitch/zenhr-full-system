# ZenJO production environment template
# Copy into your deployment secret manager or platform env config.
# Do not commit populated production values.

NODE_ENV=production
APP_VERSION=2026.05.14
PORT=3001
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/zenhr
JWT_SECRET=replace-with-a-long-random-production-secret
CORS_ORIGINS=https://app.example.com
TRUST_PROXY=true
JSON_BODY_LIMIT=1mb
UPLOADS_DIR=/app/uploads
EXPORTS_DIR=/app/exports
RUNTIME_STORE_ADAPTER=memory
# Future distributed runtime:
# RUNTIME_STORE_ADAPTER=redis
# REDIS_URL=redis://redis:6379/0
STORAGE_ADAPTER=local
# Future object storage:
# STORAGE_ADAPTER=s3
# S3_BUCKET=zenjo-production
# S3_REGION=us-east-1
# S3_ENDPOINT=
SAAS_LIMIT_ENFORCEMENT=warn
