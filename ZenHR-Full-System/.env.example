# ZenJO local development environment
# Copy to .env locally. Do not commit real secrets.

NODE_ENV=development
APP_VERSION=local-dev
PORT=3001
DATABASE_URL=postgresql://postgres:123@localhost:5432/zenhr
JWT_SECRET=change-this-local-secret-at-least-32-characters
CORS_ORIGINS=http://localhost:4200,http://localhost:5019
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
UPLOADS_DIR=uploads
EXPORTS_DIR=exports
RUNTIME_STORE_ADAPTER=memory
REDIS_URL=
STORAGE_ADAPTER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
SAAS_LIMIT_ENFORCEMENT=warn
