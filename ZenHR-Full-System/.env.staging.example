NODE_ENV=production
APP_VERSION=staging
PORT=3001
DATABASE_URL=postgresql://USER:PASSWORD@postgres:5432/zenhr_staging
JWT_SECRET=replace-with-a-long-random-staging-secret
CORS_ORIGINS=https://staging.example.com
TRUST_PROXY=true
JSON_BODY_LIMIT=1mb
UPLOADS_DIR=/app/uploads
EXPORTS_DIR=/app/exports
RUNTIME_STORE_ADAPTER=memory
# RUNTIME_STORE_ADAPTER=redis
# REDIS_URL=redis://redis:6379/0
STORAGE_ADAPTER=local
# STORAGE_ADAPTER=s3
# S3_BUCKET=zenjo-staging
# S3_REGION=us-east-1
SAAS_LIMIT_ENFORCEMENT=warn
